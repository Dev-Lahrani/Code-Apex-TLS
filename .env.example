APP_NAME="Code Apex API" # Human-friendly name for the FastAPI service
APP_ENV=development # Deployment environment (development/production)
APP_DEBUG=false # Enables FastAPI debug mode and auto-reload
APP_HOST=0.0.0.0 # Host interface for the backend server
APP_PORT=8000 # Port the backend server listens on
LOG_LEVEL=info # Logging level for backend output
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/codeapex # Async database DSN for the backend
REDIS_ENABLED=false # Toggle Redis-backed features
REDIS_URL=redis://localhost:6379/0 # Redis connection URL when Redis is enabled
BLOCKCHAIN_ENABLED=false # Toggle blockchain logging/integration
BLOCKCHAIN_RPC_URL=https://your-rpc-endpoint # RPC endpoint for the target blockchain network
BLOCKCHAIN_PRIVATE_KEY=changeme # Private key used for blockchain transactions
BLOCKCHAIN_CONTRACT_ADDRESS=0xcontractaddress # Deployed blockchain contract address
BLOCKCHAIN_CHAIN_ID=1 # Chain ID of the target blockchain network
BLOCKCHAIN_SENDER_ADDRESS=0xsenderaddress # Default sender wallet address for blockchain calls
ACCESS_REQUEST_TTL_SECONDS=3600 # Backend TTL (seconds) before access requests expire
PINATA_API_KEY=changeme # Pinata API key for IPFS uploads
PINATA_SECRET_API_KEY=changeme # Pinata secret API key for IPFS uploads
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000 # Base URL of the backend API used by the frontend
NEXT_PUBLIC_ACCESS_REQUEST_TTL_MS=3600000 # Frontend cache TTL (ms) for access requests
POSTGRES_DB=zerotrust # Database name for the Postgres service
POSTGRES_USER=dev # Database user for the Postgres service
POSTGRES_PASSWORD=changeme # Database password for the Postgres service
NODE_ENV=development # Node/Next runtime environment
